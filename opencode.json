{"$schema": "https://opencode.ai/config.json", "default_agent": "devops-engine", "agent": {"devops-engine": {"description": "DevOps agent focused on CI/CD, containerization, and infrastructure management.", "model": "opencode/claude-3-5-sonnet", "prompt": "You are a professional DevOps engineer.", "tools": {"bash": true, "filesystem-read": true, "filesystem-write": true, "mcp_github": true, "mcp_supabase": true, "mcp_context7": true, "mcp_browsermcp": true, "mcp_fetch": true, "mcp_filesystem": true, "mcp_ripgrep": true, "mcp_websearch": true}}, "database-administrator": {"description": "Database administrator agent focused on design, optimization, and management.", "model": "opencode/claude-3-5-sonnet", "prompt": "You are a senior database administrator.", "tools": {"bash": true, "filesystem-read": true, "filesystem-write": true, "mcp_supabase": true, "mcp_filesystem": true}}, "security-engineer": {"description": "Security engineer agent focused on audits, vulnerability detection, and hardening.", "model": "opencode/claude-3-5-sonnet", "prompt": "You are a security engineer.", "tools": {"bash": true, "filesystem-read": true, "mcp_github": true, "mcp_websearch": true, "mcp_fetch": true}}}, "mcp": {"github": {"type": "local", "command": ["npx", "-y", "@modelcontextprotocol/server-github@latest"], "enabled": true, "timeout": 30000, "environment": {"GITHUB_TOKEN": "${GITHUB_TOKEN}"}}, "supabase": {"type": "local", "command": ["npx", "-y", "@supabase/mcp-server-supabase@latest"], "enabled": true, "timeout": 30000, "environment": {"SUPABASE_ACCESS_TOKEN": "${SUPABASE_SERVICE_ROLE_KEY}", "SUPABASE_PROJECT_ID": "${SUPABASE_PROJECT_ID}", "SUPABASE_API_URL": "${SUPABASE_URL}"}}, "context7": {"type": "local", "command": ["npx", "-y", "@upstash/context7-mcp@latest"], "enabled": true, "timeout": 30000, "environment": {"CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"}}, "browsermcp": {"type": "local", "command": ["npx", "-y", "@browsermcp/mcp@latest"], "enabled": true, "timeout": 30000}, "fetch": {"type": "local", "command": ["npx", "-y", "@kazuph/mcp-fetch@latest"], "enabled": true, "timeout": 30000}, "filesystem": {"type": "local", "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem@latest", "./workspace"], "enabled": true, "timeout": 30000}, "ripgrep": {"type": "local", "command": ["npx", "-y", "mcp-ripgrep@latest"], "enabled": true, "timeout": 30000}, "websearch": {"type": "local", "command": ["npx", "-y", "@zhafron/mcp-web-search@latest"], "enabled": true, "timeout": 30000, "environment": {"BOCHA_API_KEY": "${BOCHA_API_KEY}"}}}}